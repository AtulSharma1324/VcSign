# ===========================
# AI Sign Language Video Call Translator
# Environment Variables
# ===========================

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- General ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signlang_vc
DB_HOST=localhost
DB_PORT=5432
DB_NAME=signlang_vc
DB_USER=postgres
DB_PASSWORD=postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- OAuth 2.0 (Google) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4001/api/auth/oauth/google/callback

# --- Service Ports ---
FRONTEND_PORT=3000
SIGNALING_PORT=4000
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
CALL_SERVICE_PORT=4003
CHAT_SERVICE_PORT=4004

# --- AI Service Ports ---
SIGN_RECOGNITION_PORT=8000
STT_PORT=8001
TTS_PORT=8002
NLP_PORT=8003

# --- AI Service URLs ---
SIGN_RECOGNITION_URL=http://localhost:8000
STT_URL=http://localhost:8001
TTS_URL=http://localhost:8002
NLP_URL=http://localhost:8003

# --- TURN Server ---
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpassword
STUN_SERVER_URL=stun:stun.l.google.com:19302

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=signlang-vc-recordings

# --- Google Cloud TTS (fallback) ---
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# --- Whisper Model ---
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Sign Language Model ---
SIGN_MODEL_PATH=weights/isl_lstm_v1.pt
SIGN_MODEL_VERSION=v1
SIGN_LANGUAGE=ISL

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
