# ===========================
# SignLang VC - Vercel Environment Variables
# ===========================

# These variables need to be set in your Vercel Project Settings

# 1. API URLs (Point these to your Render web service URLs)
NEXT_PUBLIC_API_URL=https://vc-signaling-server.onrender.com
NEXT_PUBLIC_AUTH_URL=https://vc-auth-service.onrender.com/api/auth
NEXT_PUBLIC_USER_URL=https://vc-user-service.onrender.com/api/users
NEXT_PUBLIC_SIGNALING_URL=https://vc-signaling-server.onrender.com

# 2. AI Services (Since we migrated to client-side inference, you can leave these blank/default, 
# but they are preserved here for backwards compatibility if needed)
NEXT_PUBLIC_SIGN_AI_WS=
NEXT_PUBLIC_STT_WS=
NEXT_PUBLIC_TTS_URL=
NEXT_PUBLIC_NLP_URL=
